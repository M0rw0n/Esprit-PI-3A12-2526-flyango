{% extends "base.html.twig" %}

{% block title %}Changer mon mot de passe - Fly & Go{% endblock %}

{% block extra_css %}
    <link rel="stylesheet" href="{{ asset('css/profil.css') }}">
{% endblock %}

{% block navbar %}
<nav class="navbar navbar-dark navbar-expand-lg" style="background: linear-gradient(to right, #1e4d7b, #0d2137);">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="#">
            ✈️ <span style="color: #F78D00;">FLY & GO</span>
        </a>
    </div>
</nav>
{% endblock %}

{% block content %}
<div class="container profil-edit-container">
    <h2 class="mb-4">Changer mon mot de passe</h2>

    <div class="profil-edit-card">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <div class="mb-3">
            {{ form_row(form.currentPassword, {'attr': {'class': 'form-control form-control-lg'}}) }}
        </div>

        <div class="mb-3">
            {{ form_row(form.newPassword.first, {'attr': {'class': 'form-control form-control-lg'}, 'label': 'Nouveau mot de passe'}) }}
        </div>

        <div class="mb-3">
            {{ form_row(form.newPassword.second, {'attr': {'class': 'form-control form-control-lg'}, 'label': 'Confirmer le nouveau mot de passe'}) }}
        </div>

        <div class="button-group">
            <button type="submit" class="btn btn-primary-flygo">🔑 Changer le mot de passe</button>
            <a href="{{ path('app_profil') }}" class="btn btn-outline-secondary">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
