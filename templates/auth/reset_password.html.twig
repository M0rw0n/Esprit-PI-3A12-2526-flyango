{% extends "base.html.twig" %}

{% block title %}Réinitialiser le mot de passe - Fly & Go{% endblock %}

{% block extra_css %}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block navbar %}{% endblock %}

{% block content %}
<div class="auth-container">
    <div class="auth-gradient-bg"></div>
    
    <div class="d-flex align-items-center justify-content-center min-vh-100">
        <div class="auth-card">
            <!-- Header -->
            <div class="auth-header">
                <div class="auth-icon">✈️</div>
                <h1 class="auth-title">FLY & GO</h1>
                <p class="auth-subtitle">Créez un nouveau mot de passe</p>
            </div>

            <!-- Form -->
            <form method="post" novalidate>
                <!-- New Password -->
                <div class="mb-3">
                    <label for="new_password" class="form-label">🔑 Nouveau mot de passe</label>
                    <input type="password" 
                           id="new_password" 
                           name="new_password" 
                           class="input-field form-control" 
                           placeholder="Entrez votre nouveau mot de passe"
                           required>
                    <small class="form-text text-muted">Minimum 6 caractères avec lettres et chiffres</small>
                </div>

                <!-- Confirm Password -->
                <div class="mb-3">
                    <label for="confirm_password" class="form-label">🔑 Confirmer le mot de passe</label>
                    <input type="password" 
                           id="confirm_password" 
                           name="confirm_password" 
                           class="input-field form-control" 
                           placeholder="Confirmez votre nouveau mot de passe"
                           required>
                </div>

                <!-- Submit button -->
                <button type="submit" class="btn btn-primary-flygo w-100">
                    <span>✅ Réinitialiser le mot de passe</span>
                </button>
            </form>

            <!-- Back to login -->
            <p class="auth-footer-text">
                <a href="{{ path('app_login') }}" class="auth-link">Retour à la connexion</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
