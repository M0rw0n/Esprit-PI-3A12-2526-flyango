{% extends "base.html.twig" %}

{% block title %}Mot de passe oublié - Fly & Go{% endblock %}

{% block extra_css %}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block navbar %}{% endblock %}

{% block content %}
<div class="auth-container">
    <div class="auth-gradient-bg"></div>
    
    <div class="d-flex align-items-center justify-content-center min-vh-100">
        <div class="auth-card">
            <!-- Header -->
            <div class="auth-header">
                <div class="auth-icon">✈️</div>
                <h1 class="auth-title">FLY & GO</h1>
                <p class="auth-subtitle">Réinitialiser votre mot de passe</p>
            </div>

            <!-- Form -->
            <form method="post" novalidate>
                <!-- Email -->
                <div class="mb-3">
                    <label for="email" class="form-label">📧 Email</label>
                    <input type="email" 
                           id="email" 
                           name="email" 
                           class="input-field form-control" 
                           placeholder="votre@email.com"
                           required>
                    <small class="form-text text-muted">Entrez l'email associé à votre compte</small>
                </div>

                <!-- Submit button -->
                <button type="submit" class="btn btn-primary-flygo w-100">
                    <span>📧 Envoyer le lien de réinitialisation</span>
                </button>
            </form>

            <!-- Back to login -->
            <p class="auth-footer-text">
                <a href="{{ path('app_login') }}" class="auth-link">Retour à la connexion</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
