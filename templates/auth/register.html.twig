{% extends "base.html.twig" %}

{% block title %}Inscription - Fly & Go{% endblock %}

{% block extra_css %}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block navbar %}{% endblock %}

{% block content %}
<div class="auth-container">
    <div class="auth-gradient-bg"></div>
    
    <div class="d-flex align-items-center justify-content-center min-vh-100">
        <div class="auth-card auth-card-large">
            <!-- Header -->
            <div class="auth-header">
                <div class="auth-icon">✈️</div>
                <h1 class="auth-title">FLY & GO</h1>
                <p class="auth-subtitle">Créez votre compte</p>
            </div>

            <!-- Form -->
            {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}

            <!-- Two column layout for name fields -->
            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_row(registrationForm.nom, {'attr': {'class': 'input-field form-control'}}) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(registrationForm.prenom, {'attr': {'class': 'input-field form-control'}}) }}
                </div>
            </div>

            <!-- Email -->
            <div class="mb-3">
                {{ form_row(registrationForm.email, {'attr': {'class': 'input-field form-control'}}) }}
            </div>

            <!-- Phone -->
            <div class="mb-3">
                {{ form_row(registrationForm.phone, {'attr': {'class': 'input-field form-control'}, 'required': false}) }}
                <small class="form-text text-muted">Format: +216XXXXXXXX ou optionnel</small>
            </div>

            <!-- Password -->
            <div class="mb-3">
                {{ form_row(registrationForm.motDePasse.first, {'attr': {'class': 'input-field form-control'}, 'label': 'Mot de passe'}) }}
                <small class="form-text text-muted">Minimum 6 caractères avec lettres et chiffres</small>
            </div>

            <!-- Confirm Password -->
            <div class="mb-3">
                {{ form_row(registrationForm.motDePasse.second, {'attr': {'class': 'input-field form-control'}, 'label': 'Confirmer le mot de passe'}) }}
            </div>

            <!-- Register button -->
            <button type="submit" class="btn btn-primary-flygo w-100">
                <span>✅ Créer mon compte</span>
            </button>

            {{ form_end(registrationForm) }}

            <!-- Login link -->
            <p class="auth-footer-text">
                Vous avez déjà un compte? 
                <a href="{{ path('app_login') }}" class="auth-link">Se connecter</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
